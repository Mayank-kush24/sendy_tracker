# Copy this file to .env and fill in your actual values.
# .env is intentionally excluded from version control.

# ==========================================================================
# MySQL / cPanel connection
# ==========================================================================
#
# OPTION A – Flask runs on the SAME cPanel server
#   DB_HOST=localhost
#   DB_PORT=3306
#   DB_NAME=cpanelusername_sendydb    ← cPanel prefixes names with your cPanel username
#   DB_USER=cpanelusername_sendyuser  ← same prefix
#   DB_PASSWORD=password_you_set_in_cpanel
#
# OPTION B – Flask on your LOCAL PC / different server (SSH tunnel — recommended)
#   1. Open a terminal and run (keep it open):
#        ssh -N -L 3307:127.0.0.1:3306 your_cpanel_user@your-domain.com
#   2. Set:
#        DB_HOST=127.0.0.1
#        DB_PORT=3307
#
# OPTION C – Remote MySQL (less secure)
#   1. cPanel → Remote MySQL → add your IP address
#   2. Set DB_HOST=your-domain.com
#
# Note: find your exact DB_NAME and DB_USER in cPanel → MySQL Databases.
# ==========================================================================

# ── Fill these in ──────────────────────────────────────────────────────────
DB_HOST=your-domain.com          # server hostname or IP from cPanel
DB_PORT=3306
DB_NAME=cpanelusername_sendydb   # cPanel → MySQL Databases → Database Name
DB_USER=cpanelusername_sendyuser # cPanel → MySQL Databases → Username
DB_PASSWORD=your_db_password     # password you set when creating the DB user

# Remote connection extras (Option C)
DB_CONNECT_TIMEOUT=10            # TCP timeout in seconds — increase if server is slow
# Socket read/write for running queries (seconds). Raise if large reports hit timeouts.
DB_READ_TIMEOUT=180
DB_WRITE_TIMEOUT=180
DB_SSL=false                     # set to true if your host requires SSL
DB_CHARSET=utf8mb4

# Optional – connection pool tuning
DB_POOL_SIZE=3                   # keep low for shared hosting (max_connections limits)
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800             # recycle connections every 30 min (avoids idle drops)

# --- Flask ---
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
# Local dev: set true so .py changes reload automatically (werkzeug reloader).
# Production: keep false and restart the process after code deploys.
FLASK_DEBUG=false
# Reload dashboard.html etc. on every request without restarting (default true).
# Set to false only if you want Flask to cache templates in memory.
FLASK_TEMPLATES_AUTO_RELOAD=true

# --- Cache (Redis strongly recommended for faster loads & multi-worker) ---
#
# Local Redis (Docker):
#   docker run -d --name redis -p 6379:6379 redis:7-alpine
#   REDIS_URL=redis://127.0.0.1:6379/0
#
# TLS / managed (e.g. Upstash):
#   REDIS_URL=rediss://default:PASSWORD@HOST:6379
#
# Password:
#   REDIS_URL=redis://:yourpassword@127.0.0.1:6379/0
#
REDIS_URL=
# Optional tuning (defaults shown)
# REDIS_SOCKET_CONNECT_TIMEOUT=3
# REDIS_SOCKET_TIMEOUT=3
# REDIS_MAX_CONNECTIONS=32
# REDIS_HEALTH_CHECK_INTERVAL=30
# CACHE_KEY_PREFIX=st          # all keys: {prefix}:<sha256> — change if sharing Redis
CACHE_TTL_SECONDS=120          # default TTL when @cached() has no ttl (raise for fewer DB hits)
CACHE_MAXSIZE=512              # in-process fallback only; ignored when Redis works

# --- Pagination ---
DEFAULT_PAGE_LIMIT=100  # rows returned when ?limit= is omitted
MAX_PAGE_LIMIT=1000     # hard ceiling for ?limit=

# --- User engagement (opens/clicks per subscriber) ---
# How many recent campaigns to parse ``opens`` longtext for (higher = slower).
ENGAGEMENT_PARSE_CAMPAIGNS=25

# --- Dashboard campaign name list (/api/stats?type=campaigns) ---
# Hard cap on rows returned (default 5000). Default fetch size when no campaign_limit param:
CAMPAIGN_PERF_MAX=5000
CAMPAIGN_PERF_DEFAULT=2500
# Avg Open/Click cards: max campaigns to scan (opens/links). Raise only if DB is fast; lower if timeouts.
CAMPAIGN_ENGAGEMENT_SUMMARY_MAX=180
